<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Password Policy Evaluator</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f4f7f6; color: #333; margin: 0; padding: 20px; }
        .container { max-width: 900px; margin: auto; background: white; padding: 30px; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
        h1, h2, h3 { color: #2c3e50; }
        .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
        .form-group { margin-bottom: 15px; }
        label { display: block; font-weight: bold; margin-bottom: 5px; }
        input[type="number"] { width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box; }
        .checkbox-group { display: flex; align-items: center; margin-bottom: 10px; }
        .checkbox-group input { margin-right: 10px; }
        button { background-color: #0056b3; color: white; padding: 10px 20px; border: none; border-radius: 4px; cursor: pointer; font-size: 16px; width: 100%; }
        button:hover { background-color: #004494; }
        
        #dashboard { display: none; margin-top: 30px; padding-top: 20px; border-top: 2px solid #eee; }
        .score-card { text-align: center; padding: 20px; border-radius: 8px; color: white; margin-bottom: 20px; }
        .risk-Low { background-color: #27ae60; }
        .risk-Medium { background-color: #f39c12; }
        .risk-High { background-color: #c0392b; }
        .score-text { font-size: 48px; font-weight: bold; margin: 0; }
        ul.recommendations { background: #fdfdfd; border-left: 4px solid #0056b3; padding: 15px 15px 15px 35px; min-height: 20px;}
        ul.recommendations li { margin-bottom: 10px; }
        
        .disclaimer { font-size: 0.85em; color: #7f8c8d; margin-top: 20px; text-align: center; }
    </style>
</head>
<body>

<div class="container">
    <h1>Password Policy Check & Safety</h1>
    <p>Submit your organizational password policy rules below to receive a security evaluation mapped to modern standards. <br><strong>Do not enter real passwords or PII.</strong></p>

    <form id="policyForm">
        <div class="grid">
            <div>
                <h3>Length & Rotation</h3>
                <div class="form-group">
                    <label for="min_length">Minimum Password Length *</label>
                    <input type="number" id="min_length" name="min_length" required min="1">
                </div>
                <div class="form-group">
                    <label for="max_length">Maximum Password Length (0 if none)</label>
                    <input type="number" id="max_length" name="max_length" required min="0">
                </div>
                <div class="form-group">
                    <label for="expiration_days">Password Rotation/Expiration Days (0 if none) *</label>
                    <input type="number" id="expiration_days" name="expiration_days" required min="0">
                </div>
                <div class="form-group">
                    <label for="password_history_count">Password History Count *</label>
                    <input type="number" id="password_history_count" name="password_history_count" required min="0">
                </div>
            </div>

            <div>
                <h3>Lockout & Complexity</h3>
                <div class="form-group">
                    <label for="lockout_threshold">Lockout Threshold (Failed attempts) *</label>
                    <input type="number" id="lockout_threshold" name="lockout_threshold" required min="0">
                </div>
                <div class="form-group">
                    <label for="lockout_duration_minutes">Lockout Duration (Minutes) *</label>
                    <input type="number" id="lockout_duration_minutes" name="lockout_duration_minutes" required min="0">
                </div>

                <div class="checkbox-group">
                    <input type="checkbox" id="uppercase_required" name="uppercase_required"> 
                    <label for="uppercase_required">Require Uppercase</label>
                </div>
                <div class="checkbox-group">
                    <input type="checkbox" id="lowercase_required" name="lowercase_required"> 
                    <label for="lowercase_required">Require Lowercase</label>
                </div>
                <div class="checkbox-group">
                    <input type="checkbox" id="numbers_required" name="numbers_required"> 
                    <label for="numbers_required">Require Numbers</label>
                </div>
                <div class="checkbox-group">
                    <input type="checkbox" id="special_chars_required" name="special_chars_required"> 
                    <label for="special_chars_required">Require Special Characters</label>
                </div>
                <div class="checkbox-group">
                    <input type="checkbox" id="mfa_required" name="mfa_required"> 
                    <label for="mfa_required">MFA Required *</label>
                </div>
            </div>
        </div>
        
        <div class="checkbox-group" style="margin-top: 15px;">
            <input type="checkbox" id="tos" name="tos" required> 
            <label for="tos" style="font-weight: normal;">I agree to the Terms of Service and confirm no real credentials are included.</label>
        </div>

        <button type="submit">Evaluate Policy</button>
    </form>

    <div id="dashboard">
        <h2>Assessment Dashboard</h2>
        <div id="scoreCard" class="score-card">
            <h3>Security Score</h3>
            <p class="score-text" id="displayScore">0/100</p>
            <p id="displayRisk">Risk Level: Unknown</p>
        </div>
        
        <h3>Findings & Recommendations</h3>
        <ul class="recommendations" id="recommendationsList">
        </ul>
        
        <div class="disclaimer">
            * Validation logs: Schema checked. Score bounded (0-100). No PII stored.
        </div>
    </div>
</div>

<script>
    document.getElementById('policyForm').addEventListener('submit', function(e) {
        e.preventDefault();

        const policy = {
            min_length: parseInt(document.getElementById('min_length').value, 10),
            max_length: parseInt(document.getElementById('max_length').value, 10),
            expiration_days: parseInt(document.getElementById('expiration_days').value, 10),
            password_history_count: parseInt(document.getElementById('password_history_count').value, 10),
            lockout_threshold: parseInt(document.getElementById('lockout_threshold').value, 10),
            lockout_duration_minutes: parseInt(document.getElementById('lockout_duration_minutes').value, 10),
            uppercase_required: document.getElementById('uppercase_required').checked,
            lowercase_required: document.getElementById('lowercase_required').checked,
            numbers_required: document.getElementById('numbers_required').checked,
            special_chars_required: document.getElementById('special_chars_required').checked,
            mfa_required: document.getElementById('mfa_required').checked
        };

        if (isNaN(policy.min_length)) {
            alert("Validation Error: Missing required numeric fields.");
            return;
        }

        evaluatePolicy(policy);
    });

    function evaluatePolicy(policy) {
        let score = 0;
        let recommendations = [];

        if (policy.min_length >= 15) { score += 35; }
        else if (policy.min_length >= 12) { score += 25; recommendations.push("Increase minimum length to 15+ characters to resist modern cracking."); }
        else if (policy.min_length >= 8) { score += 10; recommendations.push("Minimum length of 8 is outdated. NIST recommends 8 minimum, but 12-15 is the modern standard."); }
        else { recommendations.push("CRITICAL: Minimum length is too short. Set to at least 8 (preferably 12+)."); }

        if (policy.max_length > 0 && policy.max_length < 64) {
            recommendations.push("Increase maximum password length (e.g., 64 or higher) to allow users to utilize long passphrases.");
        }

        if (policy.mfa_required) { 
            score += 30; 
        } else {
            recommendations.push("CRITICAL: Lack of Multi-Factor Authentication (MFA) leaves accounts highly vulnerable to credential stuffing and phishing.");
        }

        if (policy.lockout_threshold >= 3 && policy.lockout_threshold <= 10) { score += 10; }
        else { recommendations.push("Set a lockout threshold between 3 and 10 attempts to prevent brute force attacks."); }

        if (policy.lockout_duration_minutes >= 15) { score += 5; }
        else { recommendations.push("Increase lockout duration to at least 15 minutes to deter automated attacks."); }

        if (policy.expiration_days === 0 || policy.expiration_days > 365) { 
            score += 10; 
        } else {
            recommendations.push("Frequent password expiration (rotation) is no longer recommended by NIST as it encourages users to create weaker passwords. Consider removing forced rotation.");
        }

        let complexityCount = 0;
        if (policy.uppercase_required) complexityCount++;
        if (policy.lowercase_required) complexityCount++;
        if (policy.numbers_required) complexityCount++;
        if (policy.special_chars_required) complexityCount++;
        
        score += (complexityCount * 2.5); 
        if (complexityCount < 2 && policy.min_length < 15) {
            recommendations.push("If allowing shorter passwords, require some character complexity (though transitioning to long passphrases is preferred).");
        }

        score = Math.min(100, Math.max(0, Math.round(score)));

        let riskLevel = "";
        let riskClass = "";
        if (score >= 80) { riskLevel = "Low Risk"; riskClass = "risk-Low"; }
        else if (score >= 50) { riskLevel = "Medium Risk"; riskClass = "risk-Medium"; }
        else { riskLevel = "High Risk"; riskClass = "risk-High"; }

        if (recommendations.length === 0) {
            recommendations.push("Great job! Your policy aligns well with modern security standards.");
        }

        renderDashboard(score, riskLevel, riskClass, recommendations);
    }

    function renderDashboard(score, riskLevel, riskClass, recommendations) {
        const dashboard = document.getElementById('dashboard');
        const scoreCard = document.getElementById('scoreCard');
        const list = document.getElementById('recommendationsList');

        document.getElementById('displayScore').innerText = score + "/100";
        document.getElementById('displayRisk').innerText = "Assessed Risk: " + riskLevel;
        
        scoreCard.className = "score-card " + riskClass;

        list.innerHTML = "";
        recommendations.forEach(function(rec) {
            let li = document.createElement('li');
            li.innerText = rec;
            list.appendChild(li);
        });

        dashboard.style.display = "block";
        dashboard.scrollIntoView({ behavior: 'smooth' });
    }
</script>

</body>
</html>
